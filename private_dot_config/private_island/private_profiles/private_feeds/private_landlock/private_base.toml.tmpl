abi = 6

# Deny all supported access by default.
[[ruleset]]
handled_access_fs = ["abi.all"]
scoped = ["abi.all"]

# Allow read/execute access to system directories.
[[path_beneath]]
allowed_access = ["abi.read_execute"]
parent = ["/usr/bin",
    "/usr/lib",
]

[[variable]]
name = "XDG_CONFIG_HOME"
literal = ["{{ .chezmoi.homeDir }}/.config"]

[[variable]]
name = "XDG_DATA_HOME"
literal = ["{{ .chezmoi.homeDir }}/.local/share"]

# User configuration files.
[[path_beneath]]
allowed_access = [
    "read_dir",
    "read_file",
    "refer",
]
parent = [
    "${XDG_CONFIG_HOME}/sfeed/sfeedrc",
]

# for sfeed
[[path_beneath]]
allowed_access = ["abi.read_write"]
parent = [
     "${XDG_DATA_HOME}/sfeed",
     "/tmp",
]

# Safe writable devices.
[[path_beneath]]
allowed_access = ["abi.read_write"]
parent = [
    "/dev/full",
    "/dev/null",
    "/dev/random",
    "/dev/urandom",
    "/dev/zero",
]

# System configuration and introspection files.
[[path_beneath]]
allowed_access = [
    "read_dir",
    "read_file",
    "refer",
]
parent = [
    "/usr/share",
    "/etc/fonts",
    "/etc/resolv.conf",
    "/etc/ssl/certs",
    "/proc/self",
    "/proc/cpuinfo",
]
