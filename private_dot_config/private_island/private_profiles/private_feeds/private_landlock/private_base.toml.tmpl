abi = 6

# Deny all supported access by default.
[[ruleset]]
handled_access_fs = ["abi.all"]
scoped = ["abi.all"]

# Allow read/execute access to system directories.
[[path_beneath]]
allowed_access = ["abi.read_execute"]
parent = [
    "/usr/lib",
    "/usr/bin/mktemp",
    "/usr/bin/dash",
    "/usr/bin/printf",
    "/usr/bin/readlink",
    "/usr/bin/echo",
    "/usr/bin/date",
    "/usr/bin/rm",
    "/usr/bin/curl",
    "/usr/bin/iconv",
    "/usr/bin/cat",
    "/usr/bin/tr",
    "/usr/bin/cp",
    "/usr/bin/sfeed",
    "/usr/bin/sfeed_xmlenc",
    "/usr/bin/sfeed_curses",
    "/usr/bin/sfeed_html",
    "/usr/bin/sfeed_mbox",
    "/usr/bin/sfeed_plain",
    "/usr/bin/sfeed_web",
    "/usr/bin/sfeed_atom",
    "/usr/bin/sfeed_frames",
    "/usr/bin/sfeed_json",
    "/usr/bin/sfeed_opml_export",
    "/usr/bin/sfeed_twtxt",
    "/usr/bin/sfeed_content",
    "/usr/bin/sfeed_gopher",
    "/usr/bin/sfeed_markread",
    "/usr/bin/sfeed_opml_import",
    "/usr/bin/sfeed_update",
    "/usr/bin/sort",
    "/usr/bin/touch",
    "/usr/bin/kill",
    "/usr/bin/xargs",
    "/usr/bin/mkdir",
]

[[variable]]
name = "XDG_CONFIG_HOME"
literal = ["{{ .chezmoi.homeDir }}/.config"]

[[variable]]
name = "XDG_DATA_HOME"
literal = ["{{ .chezmoi.homeDir }}/.local/share"]

# User configuration files.
[[path_beneath]]
allowed_access = [
    "read_dir",
    "read_file",
]
parent = [
    "${XDG_CONFIG_HOME}/sfeed/sfeedrc",
]

# for sfeed
[[path_beneath]]
allowed_access = ["abi.read_write"]
parent = [
     "${XDG_DATA_HOME}/sfeed",
     "/tmp",
]

# Safe writable devices.
[[path_beneath]]
allowed_access = ["abi.read_write"]
parent = [
    "/dev/full",
    "/dev/null",
    "/dev/random",
    "/dev/urandom",
    "/dev/zero",
]

# System configuration and introspection files.
[[path_beneath]]
allowed_access = [
    "read_dir",
    "read_file",
    "refer",
]
parent = [
    "/usr/share",
    "/etc/fonts",
    "/etc/resolv.conf",
    "/etc/ssl/certs",
    "/proc/self",
    "/proc/cpuinfo",
]
